{
  "name": "sdd-coder",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:int": "vitest run --reporter=verbose --config vitest.integration.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "fastify": "^5",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "tsx": "latest",
    "typescript": "^5",
    "vitest": "latest"
  },
  "vitest": {
    "globals": true,
    "environment": "node",
    "include": ["test/**/*.test.ts"],
    "exclude": ["test/**/*.integration.ts"]
  }
}
