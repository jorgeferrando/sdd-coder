# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Absolute path to the target repo the agent will work on
REPO_PATH=

# Absolute path to the sdd-skills directory
SKILLS_PATH=

# PostgreSQL credentials (must match docker-compose.yml)
POSTGRES_USER=sdd
POSTGRES_PASSWORD=sdd
POSTGRES_DB=sdd

# Full connection string — used by the app to connect to Postgres
# In Docker: hostname is "db" (the service name)
DATABASE_URL=postgresql://sdd:sdd@db:5432/sdd

# Port the app listens on
PORT=3000
